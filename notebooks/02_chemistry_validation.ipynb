{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Notebook 02 — Layer 2: Chemistry Intuition Validation\n",
    "\n",
    "> *"The model assigned low toxicity probability to this compound. However, the aldehyde functional group present is a known reactive electrophile capable of forming covalent bonds with protein residues — a mechanism the model's training data likely underrepresents."*\n",
    "\n",
    "This notebook walks through the chemistry validation layer systematically:\n",
    "\n",
    "1. Load GNN predictions on the test set  \n",
    "2. Screen every molecule for structural alerts  \n",
    "3. Classify discrepancies (false-safe, uncertain-toxic, aligned)  \n",
    "4. Deep-dive on the most chemically concerning false-safe predictions  \n",
    "5. Generate SHAP explanations for uncertain-toxic cases  \n",
    "6. Produce the reviewer report"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import warnings\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "from IPython.display import display, HTML, Image\n",
    "from rdkit import Chem\n",
    "from rdkit.Chem import Draw\n",
    "from rdkit.Chem.Draw import rdMolDraw2D\n",
    "\n",
    "import sys\n",
    "sys.path.insert(0, '..')\n",
    "from src.data.tox21_loader import Tox21Loader, Tox21DataConfig, TOX21_TASKS\n",
    "from src.models.gnn_model import DeepChemGNNTrainer, GNNConfig\n",
    "from src.validation.chemistry_validator import ChemistryValidator, Severity\n",
    "from src.explainability.shap_analysis import FingerprintSHAPExplainer\n",
    "\n",
    "plt.rcParams.update({'figure.dpi': 120, 'font.size': 11})\n",
    "print('Ready ✓')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Load Predictions"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Load data with graph features (for GNN)\n",
    "bundle = Tox21Loader(Tox21DataConfig(featurizer_type='GraphConv')).load()\n",
    "\n",
    "# Load trained GNN (checkpoint must exist — run pipeline.py first)\n",
    "gnn_config = GNNConfig(checkpoint_dir='../results/tox21_attentivefp_scaffold/checkpoints')\n",
    "trainer = DeepChemGNNTrainer(gnn_config).build(n_tasks=12)\n",
    "gnn_probs = trainer.predict(bundle.test)   # shape: (n_test, 12)\n",
    "\n",
    "test_smiles = bundle.test.ids.tolist()\n",
    "print(f\"Loaded predictions for {len(test_smiles)} test molecules across {gnn_probs.shape[1]} tasks\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Run Chemistry Validation on All Test Predictions"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "validator = ChemistryValidator(toxicity_threshold=0.5, safe_concern_threshold=0.30)\n",
    "all_disc  = []\n",
    "\n",
    "for task_idx, task_name in enumerate(TOX21_TASKS):\n",
    "    task_probs = gnn_probs[:, task_idx].tolist()\n",
    "    disc_list  = validator.validate_batch(test_smiles, task_probs, task=task_name)\n",
    "    all_disc.extend(disc_list)\n",
    "\n",
    "report = validator.generate_report(all_disc, include_aligned=True)\n",
    "\n",
    "# Summary stats\n",
    "counts = report['discrepancy_type'].value_counts()\n",
    "print(\"\\nDiscrepancy summary:\")\n",
    "print(counts.to_string())\n",
    "print(f\"\\nTotal predictions reviewed: {len(report)}\")\n",
    "print(f\"False-safe flags (chemistry concern): {counts.get('false_safe', 0)}\")\n",
    "print(f\"Uncertain-toxic flags (model says toxic, no alerts): {counts.get('uncertain_toxic', 0)}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. False-Safe Deep Dive\n",
    "\n",
    "These are the most actionable cases: the model predicts a compound is safe,\n",
    "but chemistry identifies a known toxicophore.  They represent potential false negatives\n",
    "that would allow toxic compounds to advance in a virtual screening pipeline."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "false_safe = report[report['discrepancy_type'] == 'false_safe'].copy()\n",
    "false_safe = false_safe.sort_values('model_prob')  # lowest model prob first (most confident 'safe')\n",
    "\n",
    "print(f\"Total false-safe flags: {len(false_safe)}\")\n",
    "print(f\"\\nSeverity breakdown:\")\n",
    "print(false_safe['max_severity'].value_counts().to_string())\n",
    "\n",
    "# Display top cases\n",
    "display(false_safe[['smiles','task','model_prob','alert_names','max_severity']].head(10)\n",
    "        .style.background_gradient(subset=['model_prob'], cmap='RdYlGn'))"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### Case Walkthrough: Most Concerning False-Safe Compounds"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def draw_flagged_molecules(df, n=6, title=''):\n",
    "    \"\"\"Draw a grid of flagged molecules with alert labels.\"\"\"\n",
    "    subset = df.head(n)\n",
    "    mols   = [Chem.MolFromSmiles(s) for s in subset['smiles']]\n",
    "    mols   = [m for m in mols if m is not None]\n",
    "    labels = [\n",
    "        f\"p={row.model_prob:.2f} | {row.alert_names.split('|')[0].strip()[:30]}\"\n",
    "        for _, row in subset.iterrows() if Chem.MolFromSmiles(row.smiles)\n",
    "    ]\n",
    "    img = Draw.MolsToGridImage(\n",
    "        mols, molsPerRow=3, subImgSize=(400, 250),\n",
    "        legends=labels\n",
    "    )\n",
    "    return img\n",
    "\n",
    "# High-severity false-safe compounds only\n",
    "high_false_safe = false_safe[false_safe['max_severity'] == 'high']\n",
    "img = draw_flagged_molecules(high_false_safe, n=6, title='High-severity false-safe predictions')\n",
    "img.save('../results/figures/false_safe_molecules.png')\n",
    "display(img)\n",
    "print(f\"\\nShowing {min(6, len(high_false_safe))} high-severity false-safe compounds\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### Reviewer Notes for Top False-Safe Cases"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "for i, (_, row) in enumerate(high_false_safe.head(3).iterrows()):\n",
    "    print(f\"{'='*70}\")\n",
    "    print(f\"CASE {i+1} | Task: {row.task} | SMILES: {row.smiles[:60]}...\")\n",
    "    print(f\"{'='*70}\")\n",
    "    print(row['reviewer_note'])\n",
    "    print()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Uncertain-Toxic Investigation\n",
    "\n",
    "These compounds are predicted toxic by the model but show no structural alerts.\n",
    "Two interpretations: the model found a real signal we haven't captured in our alert library,\n",
    "OR it's a false positive from scaffold overfitting.  SHAP resolves the ambiguity."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "uncertain_tox = report[\n",
    "    (report['discrepancy_type'] == 'uncertain_toxic') &\n",
    "    (report['model_prob'] > 0.7)   # high-confidence uncertain-toxic\n",
    "].copy().sort_values('model_prob', ascending=False)\n",
    "\n",
    "print(f\"High-confidence uncertain-toxic predictions (p > 0.70): {len(uncertain_tox)}\")\n",
    "display(uncertain_tox[['smiles','task','model_prob']].head(10)\n",
    "        .style.background_gradient(subset=['model_prob'], cmap='YlOrRd'))"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### SHAP Analysis on Uncertain-Toxic Cases\n",
    "\n",
    "We use the Random Forest ECFP baseline for SHAP (TreeSHAP is exact and fast).  \n",
    "The ECFP bits with high SHAP values are decoded back to atom environments —  \n",
    "if they correspond to a recognisable substructure, this gives a chemically  \n",
    "interpretable explanation for the model's toxicity prediction."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from sklearn.ensemble import RandomForestClassifier\n",
    "from src.features.molecular_representations import MolecularRepresentation\n",
    "from src.explainability.shap_analysis import FingerprintSHAPExplainer, decode_ecfp_bit\n",
    "\n",
    "repr_calc = MolecularRepresentation()\n",
    "\n",
    "# Focus on NR-AhR (task index 2) — well-studied, good training data\n",
    "TASK_IDX = 2\n",
    "TASK_NAME = TOX21_TASKS[TASK_IDX]\n",
    "\n",
    "ecfp_bundle = Tox21Loader(Tox21DataConfig(featurizer_type='ECFP')).load()\n",
    "mask_tr     = ecfp_bundle.train.w[:, TASK_IDX] != 0\n",
    "X_tr        = ecfp_bundle.train.X[mask_tr]\n",
    "y_tr        = ecfp_bundle.train.y[mask_tr, TASK_IDX].astype(int)\n",
    "\n",
    "rf = RandomForestClassifier(n_estimators=300, class_weight='balanced',\n",
    "                             n_jobs=-1, random_state=42)\n",
    "rf.fit(X_tr, y_tr)\n",
    "\n",
    "explainer = FingerprintSHAPExplainer(rf, background_data=X_tr[:200], use_tree_explainer=True)\n",
    "print(f\"RF fitted on {len(X_tr)} labelled compounds for task: {TASK_NAME}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Compute SHAP for uncertain-toxic test compounds in NR-AhR task\n",
    "uncertain_NRAhR = uncertain_tox[uncertain_tox['task'] == TASK_NAME].head(20)\n",
    "\n",
    "if len(uncertain_NRAhR) > 0:\n",
    "    X_query  = repr_calc.batch_ecfp(uncertain_NRAhR['smiles'].tolist())\n",
    "    shap_vals = explainer.explain(X_query)\n",
    "\n",
    "    # SHAP summary plot\n",
    "    explainer.plot_summary(\n",
    "        shap_vals, X_query,\n",
    "        max_display=15,\n",
    "        save_path='../results/figures/shap_uncertain_toxic.png'\n",
    "    )\n",
    "\n",
    "    # Top driving bits\n",
    "    top_bits = explainer.top_toxic_bits(shap_vals, n=10)\n",
    "    print(f\"\\nTop ECFP bits driving NR-AhR predictions in uncertain-toxic compounds:\")\n",
    "    display(top_bits)\n",
    "\n",
    "    # Decode top bit to atom environment\n",
    "    top_bit = int(top_bits.iloc[0]['bit'])\n",
    "    sample_smiles_for_decode = uncertain_NRAhR.iloc[0]['smiles']\n",
    "    atom_idxs = decode_ecfp_bit(sample_smiles_for_decode, top_bit)\n",
    "    print(f\"\\nTop SHAP bit ({top_bit}) corresponds to atoms {atom_idxs} in {sample_smiles_for_decode[:40]}...\")\nelse:\n",
    "    print(f\"No uncertain-toxic compounds found for {TASK_NAME} in this run.\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. Alert Prevalence vs. Task Toxicity Rate\n",
    "\n",
    "Are structural alerts predictive of which assays fire?  \n",
    "If alert-positive compounds are disproportionately toxic in NR-AhR but not NR-PPAR-gamma,\n",
    "that's mechanistically meaningful — AhR is a xenobiotic receptor, PPAR-gamma is a metabolic sensor."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Compare positive rate for alert-positive vs alert-negative compounds per task\n",
    "alert_df = report.copy()\n",
    "alert_df['has_alert'] = alert_df['n_alerts'] > 0\n",
    "\n",
    "# Ground truth from test labels (not predictions)\n",
    "y_test = bundle.test.y\n",
    "w_test = bundle.test.w\n",
    "\n",
    "rows = []\n",
    "for task_idx, task in enumerate(TOX21_TASKS):\n",
    "    task_disc = alert_df[alert_df['task'] == task].copy()\n",
    "    # Map SMILES back to test label\n",
    "    smiles_to_label = {\n",
    "        test_smiles[i]: int(y_test[i, task_idx])\n",
    "        for i in range(len(test_smiles))\n",
    "        if w_test[i, task_idx] != 0\n",
    "    }\n",
    "    task_disc['true_label'] = task_disc['smiles'].map(smiles_to_label)\n",
    "    task_disc = task_disc.dropna(subset=['true_label'])\n",
    "\n",
    "    for has_alert in [True, False]:\n",
    "        subset = task_disc[task_disc['has_alert'] == has_alert]\n",
    "        if len(subset) > 0:\n",
    "            rows.append({\n",
    "                'task': task,\n",
    "                'has_alert': has_alert,\n",
    "                'pos_rate': subset['true_label'].mean(),\n",
    "                'n': len(subset),\n",
    "            })\n",
    "\n",
    "enrich_df = pd.DataFrame(rows)\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(13, 5))\n",
    "x = np.arange(len(TOX21_TASKS))\n",
    "w_bar = 0.35\n",
    "ax.bar(x - w_bar/2,\n",
    "       [enrich_df[(enrich_df.task==t)&enrich_df.has_alert]['pos_rate'].values[0]\n",
    "        if len(enrich_df[(enrich_df.task==t)&enrich_df.has_alert]) else 0\n",
    "        for t in TOX21_TASKS],\n",
    "       w_bar, label='Alert-positive compounds', color='#d62728', alpha=0.85)\n",
    "ax.bar(x + w_bar/2,\n",
    "       [enrich_df[(enrich_df.task==t)&~enrich_df.has_alert]['pos_rate'].values[0]\n",
    "        if len(enrich_df[(enrich_df.task==t)&~enrich_df.has_alert]) else 0\n",
    "        for t in TOX21_TASKS],\n",
    "       w_bar, label='Alert-negative compounds', color='#2ca02c', alpha=0.85)\n",
    "\n",
    "ax.set_xticks(x)\n",
    "ax.set_xticklabels(TOX21_TASKS, rotation=35, ha='right')\n",
    "ax.set_ylabel('True Positive Rate in Test Set')\n",
    "ax.set_title('Structural Alert Enrichment per Tox21 Assay')\n",
    "ax.legend()\n",
    "plt.tight_layout()\n",
    "plt.savefig('../results/figures/alert_enrichment.png', bbox_inches='tight')\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 6. Export Reviewer Report"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Full report\n",
    "report.to_csv('../results/reports/chemistry_validation_full.csv', index=False)\n",
    "\n",
    "# Priority action list: false-safe, high severity only\n",
    "priority = report[\n",
    "    (report['discrepancy_type'] == 'false_safe') &\n",
    "    (report['max_severity'] == 'high')\n",
    "].sort_values('model_prob')\n",
    "priority.to_csv('../results/reports/priority_chemistry_flags.csv', index=False)\n",
    "\n",
    "print(f\"Full report: {len(report)} rows → ../results/reports/chemistry_validation_full.csv\")\n",
    "print(f\"Priority flags: {len(priority)} compounds → ../results/reports/priority_chemistry_flags.csv\")\n",
    "print()\n",
    "print(\"SUMMARY FOR README / REPORT:\")\n",
    "print(f\"  • Total test predictions: {len(report)}\")\n",
    "print(f\"  • False-safe flags: {(report.discrepancy_type == 'false_safe').sum()}\")\n",
    "print(f\"  • High-severity false-safe: {len(priority)}\")\n",
    "print(f\"  • Uncertain-toxic flags: {(report.discrepancy_type == 'uncertain_toxic').sum()}\")\n",
    "print(f\"  • Aligned-toxic (model + chemistry agree): {(report.discrepancy_type == 'aligned_toxic').sum()}\")"
   ]
  }
 ],
